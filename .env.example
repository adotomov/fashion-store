DATABASE_URL=postgres://fashion_store:fashion_store@localhost:5432/fashion_store?sslmode=disable
APP_ENV=local
APP_NAME=fashion-store-api
HTTP_ADDR=:8080
LOG_LEVEL=debug
LOG_FORMAT=text

GOOGLE_CLIENT_ID=
AUTH_SIGNING_SECRET=local-dev-secret-change-me
AUTH_SESSION_TTL=720h

CORS_ALLOWED_ORIGINS=http://localhost:5173

STORAGE_ENDPOINT=https://localhost:4443
STORAGE_BUCKET=product-media
STORAGE_INSECURE_SKIP_TLS=true
